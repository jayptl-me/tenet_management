{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-fable-5",
  "effortLevel": "xhigh",
  "alwaysThinkingEnabled": true,
  "defaultMode": "auto",
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Write",
      "Read",
      "WebSearch",
      "WebFetch",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(curl * | *sh*)",
      "Bash(wget * -O * | *sh*)",
      "Bash(:(){ :|:& };:)",
      "Bash(mkfs.*)",
      "Bash(dd if=*)",
      "Bash(> /dev/sda*)",
      "Bash(chmod 777 /*)",
      "Bash(chmod -R 777 /*)",
      "Bash(git push --force * main)",
      "Bash(git push --force * master)",
      "Bash(sudo *)"
    ]
  },
  "showTurnDuration": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run format:check 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  }
}
